#!/usr/bin/with-contenv bashio
DATADIR="/var/lib/postgresql/data"
chown -R postgres:postgres "$DATADIR"
chmod 700 "$DATADIR"

if [ ! -s "$DATADIR/PG_VERSION" ]; then
    bashio::log.info "Initializing database..."
    s6-setuidgid postgres /usr/lib/postgresql/15/bin/initdb -D "$DATADIR"
    
    # Add timescaledb to preload libraries
    echo "shared_preload_libraries = 'timescaledb'" >> "$DATADIR/postgresql.conf"
    
    # Allow connections from localhost and docker network
    echo "listen_addresses = '*'" >> "$DATADIR/postgresql.conf"
    echo "host all all 0.0.0.0/0 md5" >> "$DATADIR/pg_hba.conf"
    echo "host all all 0.0.0.0/0 trust" >> "$DATADIR/pg_hba.conf"
    
    # Start temporarily to create the database
    bashio::log.info "Creating database and extensions..."
    s6-setuidgid postgres /usr/lib/postgresql/15/bin/pg_ctl -D "$DATADIR" -w start
    s6-setuidgid postgres psql -c "CREATE DATABASE spectrum_knx;" || true
    s6-setuidgid postgres psql -d spectrum_knx -c "CREATE EXTENSION IF NOT EXISTS timescaledb;" || true

    # Create the telegrams table and hypertable (mirrors db/init.sql)
    bashio::log.info "Creating telegrams schema..."
    s6-setuidgid postgres psql -d spectrum_knx -c "
        CREATE TABLE IF NOT EXISTS telegrams (
            timestamp TIMESTAMPTZ NOT NULL,
            source_address VARCHAR(20) NOT NULL,
            target_address VARCHAR(20) NOT NULL,
            telegram_type VARCHAR(50) NOT NULL,
            dpt VARCHAR(20),
            dpt_main INTEGER,
            dpt_sub INTEGER,
            raw_data BYTEA,
            value_numeric DOUBLE PRECISION,
            value_json JSONB
        );
        SELECT create_hypertable('telegrams', 'timestamp', if_not_exists => TRUE);
        CREATE INDEX IF NOT EXISTS ix_telegrams_target ON telegrams (target_address, timestamp DESC);
        CREATE INDEX IF NOT EXISTS ix_telegrams_source ON telegrams (source_address, timestamp DESC);
        CREATE INDEX IF NOT EXISTS ix_telegrams_dpt ON telegrams (dpt_main, dpt_sub, timestamp DESC);
    " || true

    s6-setuidgid postgres /usr/lib/postgresql/15/bin/pg_ctl -D "$DATADIR" -m fast -w stop
fi

bashio::log.info "Starting PostgreSQL..."
exec s6-setuidgid postgres /usr/lib/postgresql/15/bin/postgres -D "$DATADIR"
