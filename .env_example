# --- KNX Configuration ---
# Password to decrypt the ETS project file (.knxproj)
# Note: For production use, it is recommended to set these explicitly.
# If you remove KNX_PASSWORD and KNX_PROJECT_PATH, you will be prompted
# to upload them via the web interface on first startup.
KNX_PASSWORD=myprojectpassword
KNX_PROJECT_PATH=/project/knx_project.knxproj

# IP address of your KNX IP Gateway/Router. Use 'AUTO' to scan the network.
KNX_GATEWAY_IP=AUTO

# Port of your KNX IP Gateway (default is 3671)
KNX_GATEWAY_PORT=3671

# --- Advanced KNX Connection Settings (Optional) ---
# Connection Type: AUTOMATIC, TUNNELING, TUNNELING_TCP, TUNNELING_TCP_SECURE, ROUTING, ROUTING_SECURE
# KNX_CONNECTION_TYPE=AUTOMATIC

# Local interface IP or name to bind to
# KNX_LOCAL_IP=192.168.1.50

# Individual address (source address for routing or specific tunnel selection)
# KNX_INDIVIDUAL_ADDRESS=15.15.250

# Enable route back for NAT/Docker bridge environments
# KNX_ROUTE_BACK=false

# --- Multicast Settings (for ROUTING connection types) ---
# KNX_MULTICAST_GROUP=224.0.23.12
# KNX_MULTICAST_PORT=3671

# --- KNX Secure Settings ---
# Mode 1: Using a knxkeys file
# KNX_KNXKEYS_FILE=/project/my.knxkeys
# KNX_KNXKEYS_PASSWORD=secret

# Mode 2: Manual credentials for Secure Tunneling
# KNX_SECURE_USER_ID=1
# KNX_SECURE_USER_PASSWORD=usersecret
# KNX_SECURE_DEVICE_PASSWORD=devicesecret

# Mode 3: Secure Routing
# KNX_SECURE_BACKBONE_KEY=00112233445566778899aabbccddeeff
# KNX_SECURE_LATENCY_MS=1000

# --- Database Configuration ---
# These are used by the TimescaleDB container AND the backend
POSTGRES_USER=knxuser
POSTGRES_PASSWORD=knxpassword
POSTGRES_DB=knx_analyzer
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Optional override: Provide a full SQLAlchemy connection string
# DATABASE_URL=postgresql+asyncpg://knxuser:knxpassword@db:5432/knx_analyzer

# --- Application Settings ---
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Full image name for the application (Docker/GHCR)
# Used by docker-compose.yml 
APP_IMAGE=ghcr.io/martinhoefling/spectrum-knx:latest

# --- Frontend Settings ---
# API URL used by the frontend (mostly for production/docker builds)
VITE_API_URL=http://localhost:8000
